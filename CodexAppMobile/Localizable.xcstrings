    "WebSocket handshake failed before app-server initialization. Verify the app-server URL is reachable and update codex-cli on the remote host if needed, or use Terminal tab.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "WebSocket handshake failed before app-server initialization. Verify the app-server URL is reachable and update codex-cli on the remote host if needed, or use Terminal tab."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "app-server 初期化前に WebSocket ハンドシェイクが失敗しました。app-server URL への到達性を確認し、必要であればリモートホストの codex-cli を更新するか、Terminal タブを使用してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 app-server 初始化前 WebSocket 握手失败。请确认 app-server URL 可达，并在需要时更新远程主机上的 codex-cli，或改用 Terminal 标签页。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 app-server 初始化前 WebSocket 握手失敗。請確認 app-server URL 可達，並在需要時更新遠端主機上的 codex-cli，或改用 Terminal 分頁。"
          }
        }
