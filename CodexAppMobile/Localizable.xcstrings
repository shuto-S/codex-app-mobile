          "stringUnit": {
            "state": "translated",
            "value": "計画モードを有効化しました。サーバー対応は不明ですが、送信時に試行します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已启用计划模式。服务器能力未知，发送时将尝试使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已啟用計畫模式。伺服器能力未知，傳送時將嘗試使用。"
          }
        }
      }
    },
    "Plan mode enabled. This server may not support it; we will retry without it if rejected.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plan mode enabled. This server may not support it; we will retry without it if rejected."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "計画モードを有効化しました。このサーバーは未対応の可能性があります。拒否された場合は無効で再試行します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已启用计划模式。此服务器可能不支持；若被拒绝将自动重试默认模式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已啟用計畫模式。此伺服器可能不支援；若被拒絕將自動以預設模式重試。"
          }
        }
      }
    },
    "Plan mode was not applied by the server. Prompt sent in default mode.": {
      "localizations": {
